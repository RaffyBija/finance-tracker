generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                 String    @id @default(uuid())
  email              String    @unique
  password           String
  name               String
  isPro              Boolean   @default(false)
  tourCompleted      Boolean   @default(false)
  currency           String    @default("EUR")
  isEmailVerified    Boolean   @default(false)
  emailVerifyToken   String?
  emailVerifyExpires DateTime?
  passwordResetToken String?
  passwordResetExpires DateTime?
  pendingEmail         String?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  transactions           Transaction[]
  categories             Category[]
  budgets                Budget[]
  recurringTransactions  RecurringTransaction[]
  plannedTransactions    PlannedTransaction[]
  accounts               Account[]
  billingCycles          BillingCycle[]

  @@map("users")
}

model Account {
  id              String      @id @default(uuid())
  userId          String
  name            String
  type            AccountType
  color           String      @default("#0d9488")
  icon            String?
  isDefault       Boolean     @default(false)
  openingBalance  Decimal     @default(0) @db.Decimal(10, 2)

  // Solo CREDIT_CARD
  creditLimit     Decimal?    @db.Decimal(10, 2)
  billingDay      Int?        // giorno di addebito (es. 15)
  closingDay      Int?        // giorno di chiusura ciclo (es. 1) — resetta la CC e crea la pianificata
  linkedAccountId String?

  user            User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  linkedAccount   Account?    @relation("CCLink", fields: [linkedAccountId], references: [id], onDelete: SetNull)
  linkedCC        Account[]   @relation("CCLink")

  transactions          Transaction[]
  recurringTransactions RecurringTransaction[]
  plannedTransactions   PlannedTransaction[]
  ccBillingPlanned      PlannedTransaction[]  @relation("CCBillingPlanned")
  billingCycles         BillingCycle[]

  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  @@unique([userId, name])
  @@index([userId])
  @@map("accounts")
}

enum AccountType {
  BANK
  CREDIT_CARD
}

model Category {
  id        String   @id @default(uuid())
  name      String
  type      TransactionType
  color     String?
  icon      String?
  userId    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user                  User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions          Transaction[]
  budgets               Budget[]
  recurringTransactions RecurringTransaction[]
  plannedTransactions   PlannedTransaction[]

  @@unique([userId, name, type])
  @@map("categories")
}

model Transaction {
  id              String          @id @default(uuid())
  amount          Decimal         @db.Decimal(10, 2)
  type            TransactionType
  description     String?
  date            DateTime        @default(now())
  categoryId      String?
  userId          String
  fromRecurringId String?
  accountId       String?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  category Category? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  account  Account?  @relation(fields: [accountId], references: [id], onDelete: SetNull)

  @@index([userId, date])
  @@index([userId, type])
  @@index([userId, accountId])
  @@map("transactions")
}

model Budget {
  id         String   @id @default(uuid())
  name       String
  amount     Decimal  @db.Decimal(10, 2)
  categoryId String?
  period     BudgetPeriod @default(MONTHLY)
  startDate  DateTime
  endDate    DateTime?
  userId     String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  category Category? @relation(fields: [categoryId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@map("budgets")
}

model RecurringTransaction {
  id          String          @id @default(uuid())
  amount      Decimal         @db.Decimal(10, 2)
  type        TransactionType
  description String
  categoryId  String?
  frequency   Frequency       @default(MONTHLY)
  dayOfMonth  Int?
  startDate   DateTime
  endDate     DateTime?
  isActive         Boolean         @default(true)
  lastExecutedDate DateTime?
  userId           String
  accountId        String?
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  category Category? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  account  Account?  @relation(fields: [accountId], references: [id], onDelete: SetNull)

  @@index([userId, isActive])
  @@map("recurring_transactions")
}

model PlannedTransaction {
  id          String          @id @default(uuid())
  amount      Decimal         @db.Decimal(10, 2)
  type        TransactionType
  description String
  categoryId  String?
  plannedDate DateTime
  isPaid      Boolean         @default(false)
  notes       String?
  userId      String
  accountId   String?
  ccAccountId String?         // se valorizzato: è il pagamento mensile di questa CC
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  category  Category? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  account   Account?  @relation(fields: [accountId], references: [id], onDelete: SetNull)
  ccAccount Account?  @relation("CCBillingPlanned", fields: [ccAccountId], references: [id], onDelete: SetNull)
  billingCycle BillingCycle? @relation("CyclePlanned")

  @@index([userId, plannedDate])
  @@index([userId, isPaid])
  @@map("planned_transactions")
}

// Ciclo di fatturazione di una carta di credito.
// L'appartenenza di una transazione a un ciclo è una funzione deterministica
// della sua data e del closingDay della carta (vedi util cycleFor). Il debito di
// ogni ciclo è sempre ri-derivabile dalle transazioni nella sua finestra
// [periodStart, periodEnd], quindi inserimenti e modifiche retroattive finiscono
// nel ciclo corretto invece di "perdersi" nel ciclo corrente.
model BillingCycle {
  id          String      @id @default(uuid())
  userId      String
  accountId   String      // la carta di credito
  periodStart DateTime    // primo giorno del ciclo (giorno dopo il closingDay precedente)
  periodEnd   DateTime    // closingDay di questo ciclo (incluso)
  status      CycleStatus @default(OPEN)
  closedAt    DateTime?
  billingDate DateTime?   // scadenza del pagamento (billingDay)
  debtAmount  Decimal     @default(0) @db.Decimal(10, 2) // snapshot alla chiusura, ricalcolato
  plannedTransactionId String? @unique // pagamento collegato a questo ciclo

  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  account Account @relation(fields: [accountId], references: [id], onDelete: Cascade)
  planned PlannedTransaction? @relation("CyclePlanned", fields: [plannedTransactionId], references: [id], onDelete: SetNull)

  @@unique([accountId, periodStart])
  @@index([userId, accountId])
  @@index([accountId, status])
  @@map("billing_cycles")
}

enum CycleStatus {
  OPEN
  CLOSED
}

enum TransactionType {
  INCOME
  EXPENSE
}

enum BudgetPeriod {
  WEEKLY
  MONTHLY
  YEARLY
}

enum Frequency {
  WEEKLY
  MONTHLY
  YEARLY
}